{
  "name": "@gms/common-util",
  "version": "0.1.0",
  "description": "GMS Common Util",
  "license": "UNLICENSED",
  "author": "GMS Development Team",
  "sideEffects": false,
  "module": "./lib/common-util.js",
  "typings": "./lib/common-util.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "clean:build": "yarn rimraf lib/ dist/ docs/ coverage/ bundle-analyzer/ artifacts/ .cache/ junit.xml",
    "clean": "npm-run-all -s clean:build",
    "build": "yarn tsc -b ./tsconfig-build.json",
    "build:test": "yarn tsc -b ./tsconfig-test.json",
    "watch": "yarn tsc -b ./tsconfig-build.json -watch",
    "docs": "yarn clean:docs && typedoc --out docs ./src/ --name common-util --mode file --readme README.md --target ES6 --includeDeclarations --excludeExternals --excludeNotExported --hideGenerator",
    "sonar": "echo \"run 'yarn sonar' from the top-level directory\"",
    "test": "yarn test:dev",
    "test:dev:jest": "jest --maxWorkers=50% --verbose --bail",
    "test:prod:jest": "jest --maxWorkers=4 --silent --bail --coverageReporters=lcovonly --reporters=default --reporters=jest-junit",
    "test:dev": "npm-run-all -p build:test test:dev:jest",
    "test:prod": "npm-run-all -p build:test test:prod:jest",
    "version": "echo $npm_package_version"
  },
  "dependencies": {
    "@gms/common-model": "0.1.0",
    "csv-parse": "4.8.2",
    "fast-equals": "5.0.1",
    "immutable": "4.0.0-rc.12",
    "lodash": "4.17.21",
    "math-random": "2.0.1",
    "moment": "2.29.4",
    "uuid": "3.3.3"
  },
  "devDependencies": {
    "@testing-library/dom": "10.1.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "16.0.0",
    "@types/faker": "4.1.8",
    "@types/jest": "29.1.1",
    "@types/lodash": "4.14.149",
    "@types/node": "18.11.9",
    "@types/react": "18.3.3",
    "@types/uuid": "3.4.6",
    "faker": "4.1.0",
    "jest": "29.1.2",
    "jest-canvas-mock": "2.4.0",
    "jest-cli": "29.1.2",
    "jest-environment-jsdom": "29.1.2",
    "jest-fetch-mock": "3.0.3",
    "jest-junit": "12.2.0",
    "jsdom": "20.0.1",
    "jsdom-global": "3.0.2",
    "node-fetch": "2.6.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.1.1",
    "prettier-2": "npm:prettier@2.8.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "5.0.5",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.1",
    "typedoc": "0.15.3",
    "typescript": "5.3.3"
  },
  "jest-junit": {
    "suiteNameTemplate": "common-util/{filename}",
    "classNameTemplate": "common-util/{filename}/{classname}",
    "titleTemplate": "{title}"
  }
}
