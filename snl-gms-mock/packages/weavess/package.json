{
  "name": "@gms/weavess",
  "version": "1.3.0",
  "description": "WEAVESS: Web Enhanced Application for the Viewing & Exploitation of Sensor Samples, a library for high-performance waveform display",
  "license": "UNLICENSED",
  "author": "GMS Development Team",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "module": "./lib/weavess.js",
  "typings": "./lib/weavess.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "clean:build": "yarn rimraf lib/ dist/ docs/ coverage/ bundle-analyzer/ artifacts/ .cache/ junit.xml",
    "clean": "npm-run-all -s clean:build",
    "build": "yarn tsc -b ./tsconfig-build.json",
    "build:test": "yarn tsc -b ./tsconfig-test.json",
    "watch": "yarn tsc -b ./tsconfig-build.json -watch",
    "dev": "webpack serve --color --progress --env development --env devserver --config webpack.config.ts",
    "start": "webpack serve --color --progress --env production --env devserver --config webpack.config.ts",
    "docs": "yarn clean:docs && typedoc --out docs ./src/ --name weavess --mode file --readme README.md --target ES6 --includeDeclarations --excludeExternals --excludeNotExported --hideGenerator",
    "sonar": "echo \"run 'yarn sonar' from the top-level directory\"",
    "test": "yarn test:dev",
    "test:dev:jest": "yarn jest --verbose --bail",
    "test:prod:jest": "yarn jest --silent --bail --coverageReporters=lcovonly --reporters=default --reporters=jest-junit",
    "test:dev": "npm-run-all -p build:test test:dev:jest",
    "test:prod": "npm-run-all -p build:test test:prod:jest",
    "version": "echo $npm_package_version"
  },
  "dependencies": {
    "@blueprintjs/core": "5.16.2",
    "@blueprintjs/datetime2": "2.3.18",
    "@blueprintjs/icons": "5.15.1",
    "@gms/common-util": "0.1.0",
    "@gms/ui-util": "0.1.0",
    "@gms/weavess-core": "0.1.0",
    "@gms/webpack-config": "0.1.0",
    "classnames": "2.2.6",
    "d3": "5.5.0",
    "element-resize-event": "3.0.3",
    "fast-equals": "5.0.1",
    "immutable": "4.0.0-rc.12",
    "jest-fetch-mock": "3.0.3",
    "lodash": "4.17.21",
    "memoize-one": "6.0.0",
    "moment": "2.29.4",
    "moment-precise-range-plugin": "1.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "6.3.0",
    "react-router-dom": "6.3.0",
    "react-toastify": "10.0.5",
    "resize-observer-polyfill": "1.5.1",
    "three": "0.150.1",
    "worker-rpc": "0.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.1.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "16.0.0",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.4.3",
    "@types/classnames": "2.2.9",
    "@types/d3": "4.12.0",
    "@types/faker": "4.1.8",
    "@types/jest": "29.1.1",
    "@types/lodash": "4.14.149",
    "@types/moment-precise-range-plugin": "0.2.0",
    "@types/node": "18.11.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/testing-library__jest-dom": "5.14.5",
    "@types/three": "0.150.0",
    "copyfiles": "2.1.1",
    "css-loader": "6.7.1",
    "faker": "4.1.0",
    "jest": "29.1.2",
    "jest-canvas-mock": "2.4.0",
    "jest-cli": "29.1.2",
    "jest-environment-jsdom": "29.1.2",
    "jest-junit": "12.2.0",
    "jsdom": "20.0.1",
    "jsdom-global": "3.0.2",
    "npm-run-all": "4.1.5",
    "prettier": "3.1.1",
    "prettier-2": "npm:prettier@2.8.8",
    "react-test-renderer": "18.3.1",
    "resolve-url-loader": "5.0.0",
    "rimraf": "5.0.5",
    "sass": "1.55.0",
    "sass-loader": "13.0.2",
    "script-loader": "0.7.2",
    "source-map-loader": "4.0.0",
    "style-loader": "3.3.1",
    "ts-jest": "29.1.1",
    "ts-jest-mock-import-meta": "0.12.0",
    "ts-loader": "9.2.8",
    "ts-node": "10.9.1",
    "typedoc": "0.15.3",
    "typescript": "5.3.3",
    "webpack": "5.88.2",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "4.15.1"
  },
  "jest-junit": {
    "suiteNameTemplate": "weavess/{filename}",
    "classNameTemplate": "weavess/{filename}/{classname}",
    "titleTemplate": "{title}"
  }
}
